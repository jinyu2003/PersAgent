# Secrets and machine-local overrides only.
# Non-sensitive model defaults live in configs/llm.json.

# DeepSeek-compatible endpoint key.
DEEPSEEK_API_KEY=replace_with_your_deepseek_api_key

# OpenAI key, used when configs/llm.json or local overrides select provider=openai.
OPENAI_API_KEY=

# Optional generic key override for OpenAI-compatible providers.
# LLM_API_KEY=

# Optional local overrides. Prefer editing configs/llm.json for reproducible defaults.
# PERSAGENT_USE_LIVE_LLM=false
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# BRAIN_MODEL=gpt-4o
# KNOWLEDGE_MODEL=gpt-4o-mini
# VERIFIER_MODEL=gpt-4o-mini
# LLM_BASE_URL=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# OPENAI_BASE_URL=
# LLM_MAX_TOKENS=2048
# LLM_TEMPERATURE=0
# LLM_ATTRIBUTION_PARALLELISM=2

