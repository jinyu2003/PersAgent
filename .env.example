# Live LLM switch. Keep false for deterministic local fallback.
PERSAGENT_USE_LIVE_LLM=true

# DeepSeek first: OpenAI-compatible API endpoint.
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=replace_with_your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# Optional per-role overrides. If omitted, LLM_MODEL is used for all live Brain calls.
# BRAIN_MODEL=deepseek-v4-pro
# KNOWLEDGE_MODEL=deepseek-v4-flash
# VERIFIER_MODEL=deepseek-v4-flash

# JSON attribution prompts can be long; keep this high enough to avoid truncation.
LLM_MAX_TOKENS=2048

# Stage 1 organ-level attribution explanations run in parallel.
# Use 1 to force serial calls if the provider rate-limits you.
LLM_ATTRIBUTION_PARALLELISM=2

# To switch later to GPT/OpenAI, use:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=replace_with_your_openai_api_key
# LLM_MODEL=gpt-4o
# OPENAI_BASE_URL=
